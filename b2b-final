<script>
var D={},EMP=[],BLOGS=[],ALL_BLOGS=[],B2B_URLS=[],CHARTS=[];

// ── SANITIZER ──────────────────────────────────────────────────────────────────
// Prevent XSS when injecting strings directly into innerHTML
function esc(str) {
  if (!str) return '';
  var div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}

// ── PERSIST BLOG URLS ──────────────────────────────────────────────────────────
try{var s=localStorage.getItem('b2b_urls');if(s)B2B_URLS=JSON.parse(s);}catch(e){}
function saveURLs(u){B2B_URLS=u;try{localStorage.setItem('b2b_urls',JSON.stringify(u));}catch(e){}}

// ── FILE HANDLING ──────────────────────────────────────────────────────────────
var dz=document.getElementById('dropZone'),fi=document.getElementById('fileInput');
dz.addEventListener('dragover',function(e){e.preventDefault();dz.classList.add('over');});
dz.addEventListener('dragleave',function(){dz.classList.remove('over');});
dz.addEventListener('drop',function(e){e.preventDefault();dz.classList.remove('over');if(e.dataTransfer.files[0])parse(e.dataTransfer.files[0]);});
fi.addEventListener('change',function(e){if(e.target.files[0])parse(e.target.files[0]);});

function showErr(m){var el=document.getElementById('errMsg');el.style.display='block';el.textContent=m;}
function goBack(){document.getElementById('dashboard').style.display='none';document.getElementById('upload-screen').style.display='flex';fi.value='';}

function parse(file){
  document.getElementById('errMsg').style.display='none';
  var r=new FileReader();
  r.onload=function(e){
    try{
      var wb=XLSX.read(new Uint8Array(e.target.result),{type:'array'});
      var Q=[],P=[],C=[];
      function parseCtr(v){
        if(v===null||v===undefined||v==='')return 0;
        if(typeof v==='number')return v<=1?v*100:v;
        var s=String(v).replace('%','').trim();
        var n=parseFloat(s)||0;
        return String(v).includes('%')?n:n<=1?n*100:n;
      }
      function colIdx(hdr,keys){
        for(var i=0;i<hdr.length;i++){var h=String(hdr[i]||'').toLowerCase().trim();for(var k=0;k<keys.length;k++)if(h.includes(keys[k]))return i;}
        return -1;
      }
      wb.SheetNames.forEach(function(name){
        var n=name.toLowerCase().trim();
        if(['filters','countries','devices','search appearance','search type'].includes(n))return;
        var rows=XLSX.utils.sheet_to_json(wb.Sheets[name],{header:1,defval:''});
        rows=rows.filter(function(r){return r.some(function(c){return c!==''&&c!==null;});});
        if(rows.length<2)return;
        var hdr=rows[0],data=rows.slice(1);
        var uC=colIdx(hdr,['top page','landing','page url','page','url']);
        var qC=colIdx(hdr,['top quer','query','keyword']);
        var clkC=colIdx(hdr,['click']); if(clkC<0)clkC=1;
        var impC=colIdx(hdr,['impress']); if(impC<0)impC=2;
        var ctrC=colIdx(hdr,['ctr','click-through']); if(ctrC<0)ctrC=3;
        var posC=colIdx(hdr,['position','rank','pos']); if(posC<0)posC=4;
        var isDate=n==='chart'||n==='days'||n==='date'||n==='trend'||n.includes('chart');
        var isPage=!isDate&&(n==='pages'||n==='top pages'||uC>=0);
        var isQuery=!isDate&&!isPage&&(n==='queries'||n==='top queries'||qC>=0);
        var dC=uC>=0?uC:(qC>=0?qC:0);
        var first=data[0]?String(data[0][0]||''):'';
        if(!isPage&&!isQuery&&!isDate){
          if(first.startsWith('http'))isPage=true;
          else if(/^\d{4}-\d{2}/.test(first))isDate=true;
          else isQuery=true;
        }
        if(isPage)data.forEach(function(r){
          var u=String(r[dC]||r[0]||'').trim();
          if(u&&u.startsWith('http'))P.push({url:u,clicks:+r[clkC]||0,impr:+r[impC]||0,ctr:parseCtr(r[ctrC]),pos:parseFloat(r[posC])||0});
        });
        else if(isQuery)data.forEach(function(r){
          var q=String(r[dC]||r[0]||'').trim();
          if(q&&!q.startsWith('http'))Q.push({q:q,clicks:+r[clkC]||0,impr:+r[impC]||0,ctr:parseCtr(r[ctrC]),pos:parseFloat(r[posC])||0});
        });
        else if(isDate)data.forEach(function(r){if(r[0])C.push({d:String(r[0]).slice(0,10),clicks:+r[1]||0,impr:+r[2]||0});});
      });
      if(!P.length&&!Q.length){showErr('No data found. Sheets: '+wb.SheetNames.join(', '));return;}
      D={Q:Q,P:P,C:C,fn:file.name,site:(file.name.match(/([a-z0-9-]+\.[a-z]+)/i)||[])[1]||'unstop.com'};
      build();
    }catch(err){showErr('Error: '+err.message);}
  };
  r.readAsArrayBuffer(file);
}

// ── BUILD ──────────────────────────────────────────────────────────────────────
function build(){
  EMP=D.P.filter(function(p){return p.url.toLowerCase().includes('/employers');}).sort(function(a,b){return b.clicks-a.clicks;});
  ALL_BLOGS=D.P.filter(function(p){return p.url.toLowerCase().includes('/blog/');}).sort(function(a,b){return b.clicks-a.clicks;});
  buildBlogs();
  document.getElementById('upload-screen').style.display='none';
  document.getElementById('dashboard').style.display='block';
  document.getElementById('tb-site').textContent=esc(D.site);
  if(D.C.length>1)document.getElementById('tb-date').textContent=esc(D.C[0].d)+' to '+esc(D.C[D.C.length-1].d);
  document.getElementById('tb-pages').textContent=EMP.length+' B2B employer pages';
  document.getElementById('cnt-emp').textContent=EMP.length;
  document.getElementById('cnt-qw').textContent=EMP.filter(function(p){return p.pos>=5&&p.pos<=20;}).length;
  document.getElementById('cnt-hp').textContent=EMP.filter(function(p){return p.impr>500&&p.ctr<2&&p.pos<30;}).length;
  document.getElementById('cnt-bl').textContent=BLOGS.length;
  document.getElementById('cnt-ov').textContent=EMP.length+BLOGS.length;
  renderTab('overview');
}
function buildBlogs(){
  if(!B2B_URLS.length){BLOGS=[];return;}
  var norm=B2B_URLS.map(function(u){return u.toLowerCase().trim().replace(/\/$/,'');});
  BLOGS=ALL_BLOGS.filter(function(p){
    var pu=p.url.toLowerCase().trim().replace(/\/$/,'');
    return norm.some(function(n){return pu===n||pu.endsWith(n.replace(/.*\/blog\//,'/blog/'));});
  }).sort(function(a,b){return b.clicks-a.clicks;});
  document.getElementById('cnt-bl').textContent=BLOGS.length;
}

// ── HELPERS ────────────────────────────────────────────────────────────────────
function fmt(n){if(!n||isNaN(n))return'0';n=+n;return n>=1e6?(n/1e6).toFixed(1)+'M':n>=1000?(n/1000).toFixed(1)+'K':Math.round(n).toLocaleString();}
function sp(url){
  // Return last path segment for display
  var parts=url.replace(/\/$/,'').split('/').filter(function(s){return s.length>0;});
  return parts[parts.length-1]||url;
}
function posB(p){return p<5?'bg':p<10?'bb':p<20?'ba':'br';}
function ctrB(c){return c>5?'bg':c>2?'bb':c>1?'ba':'br';}
function urlTd(url){
  var parts=url.replace(/\/$/,'').split('/').filter(function(s){return s.length>0;});
  var slug=parts[parts.length-1]||url;
  return '<td style="min-width:180px;max-width:220px;"><a class="url-link" href="'+esc(url)+'" target="_blank" title="'+esc(url)+'">'+esc(slug)+'</a></td>';
}
function posT(p){return '<span class="b '+posB(p)+'">'+p.toFixed(1)+'</span>';}
function ctrT(c){return '<span class="b '+ctrB(c)+'">'+c.toFixed(1)+'%</span>';}

// Find related queries for a URL
function relQ(url){
  var path=url.replace(/https?:\/\/[^/]+/,'').toLowerCase();
  var segs=path.split('/').filter(function(s){return s.length>3;});
  return D.Q.filter(function(q){
    var ql=q.q.toLowerCase();
    return segs.some(function(s){return ql.includes(s.replace(/-/g,' '))||ql.includes(s.replace(/-/g,''));});
  }).sort(function(a,b){return b.impr-a.impr;}).slice(0,25);
}

// ── MODAL ──────────────────────────────────────────────────────────────────────
function openModal(title,html){
  document.getElementById('modal-title').textContent=title;
  document.getElementById('modal-body').innerHTML=html;
  document.getElementById('modal').classList.add('open');
}
function closeModal(){document.getElementById('modal').classList.remove('open');}

// Show queries for a page
function showPageQueries(url){
  var qs=relQ(url);
  var html='<div style="margin-bottom:12px;font-size:11px;color:var(--mut);">Queries matching this page path — '+qs.length+' found</div>';
  if(!qs.length){html+='<div style="color:var(--mut);font-size:12px;padding:1rem 0;">No matching queries found for this URL path. Try the Queries tab in GSC for exact mapping.</div>';}
  else{
    html+='<div class="tw"><table><thead><tr><th>Query</th><th>Clicks</th><th>Impr.</th><th>CTR</th><th>Position</th></tr></thead><tbody>';
    qs.forEach(function(q){
      html+='<tr><td style="max-width:300px;font-size:11px;white-space:normal;">'+esc(q.q)+'</td><td style="font-weight:600;color:var(--blue);">'+fmt(q.clicks)+'</td><td>'+fmt(q.impr)+'</td><td>'+ctrT(q.ctr)+'</td><td>'+posT(q.pos)+'</td></tr>';
    });
    html+='</tbody></table></div>';
  }
  openModal('Queries for: '+esc(sp(url)),html);
}

// Show cluster details
function showCluster(idx){
  var cl=window._clusters[idx];
  if(!cl)return;
  var html='<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;">';
  [['Clicks',fmt(cl.clicks),'var(--blue)'],['Impressions',fmt(cl.impr),'var(--green)'],['Avg CTR',cl.ctr.toFixed(1)+'%','var(--amber)'],['Avg Pos',cl.pos.toFixed(1),'var(--purple)']].forEach(function(s){
    html+='<div style="background:var(--surf2);border-radius:8px;padding:10px 12px;"><div style="font-size:9px;color:var(--mut);text-transform:uppercase;margin-bottom:4px;">'+s[0]+'</div><div style="font-size:20px;font-weight:700;color:'+s[2]+'>'+s[1]+'</div></div>';
  });
  html+='</div>';
  html+='<div class="tw"><table><thead><tr><th>URL</th><th>Clicks</th><th>Impr.</th><th>CTR</th><th>Pos.</th><th>Queries</th></tr></thead><tbody>';
  cl.pages.forEach(function(p){
    html+='<tr>'+urlTd(p.url)+'<td style="font-weight:600;color:var(--blue);">'+fmt(p.clicks)+'</td><td>'+fmt(p.impr)+'</td><td>'+ctrT(p.ctr)+'</td><td>'+posT(p.pos)+'</td><td><button onclick="showPageQueries(\''+esc(p.url.replace(/'/g,"\\'"))+'\');closeModal();" style="padding:3px 8px;background:var(--bdim);color:var(--blue);border:none;border-radius:5px;font-size:10px;cursor:pointer;">View</button></td></tr>';
  });
  html+='</tbody></table></div>';
  openModal(cl.icon+' '+esc(cl.name)+' — '+cl.pages.length+' pages',html);
}

// ── TAB ROUTING ────────────────────────────────────────────────────────────────
var _rendered={};
function ST(id,el){
  document.querySelectorAll('.sb-item').forEach(function(e){e.classList.remove('active');});
  if(el)el.classList.add('active');
  else{var s=document.querySelector('.sb-item[data-tab="'+id+'"]');if(s)s.classList.add('active');}
  document.querySelectorAll('.tab-sec').forEach(function(e){e.classList.remove('active');});
  var t=document.getElementById('t-'+id);if(t)t.classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
  renderTab(id);
}
function renderTab(id){
  if(_rendered[id])return;
  _rendered[id]=true;
  if(id==='overview')rOverview();
  else if(id==='employers')rEmployers();
  else if(id==='clusters')rClusters();
  else if(id==='emp-wins')rWins();
  else if(id==='emp-hp')rHP();
  else if(id==='blog-setup')rBlogSetup();
  else if(id==='blogs')rBlogs();
  else if(id==='regex')rRegex();
  else if(id==='aeo')rAEO();
  else if(id==='actions')rActions();
  else if(id==='roadmap')rRoadmap();
  else if(id==='competitors')rCompetitors();
}
function rerender(id){_rendered[id]=false;if(document.getElementById('t-'+id).classList.contains('active'))renderTab(id);}

// ── OVERVIEW ───────────────────────────────────────────────────────────────────
function rOverview(){
  var el=document.getElementById('t-overview');
  var tc=EMP.reduce(function(s,p){return s+p.clicks;},0);
  var ti=EMP.reduce(function(s,p){return s+p.impr;},0);
  var ap=EMP.length?EMP.reduce(function(s,p){return s+p.pos;},0)/EMP.length:0;
  var ac=ti?tc/ti*100:0;
  var btc=BLOGS.reduce(function(s,p){return s+p.clicks;},0);
  var bti=BLOGS.reduce(function(s,p){return s+p.impr;},0);
  var bac=bti?btc/bti*100:0;

  var dbg='';
  if(EMP.length===0&&D.P&&D.P.length>0){
    dbg='<div style="background:#2d1e05;border:1px solid var(--adim);border-radius:10px;padding:14px;margin-bottom:16px;">';
    dbg+='<div style="font-size:12px;font-weight:700;color:var(--amber);margin-bottom:8px;">⚠ 0 /employers/ pages — '+D.P.length+' total pages in file</div>';
    dbg+='<div style="font-size:11px;color:var(--mut);margin-bottom:6px;">Sample URLs found:</div>';
    dbg+='<div style="font-size:10px;font-family:monospace;background:var(--surf3);border-radius:6px;padding:8px;line-height:1.8;">';
    D.P.slice(0,5).forEach(function(p){dbg+='<div style="color:var(--green);">'+esc(p.url)+'</div>';});
    dbg+='</div><div style="font-size:11px;color:var(--mut);margin-top:8px;">Dashboard looks for URLs containing <code style="background:var(--surf3);padding:1px 4px;">/employers</code>. Make sure your GSC export has the Pages sheet.</div></div>';
  }

  var good=[],warn=[],opp=[];
  if(EMP[0])good.push({l:sp(EMP[0].url).slice(0,30),v:fmt(EMP[0].clicks)+' clicks'});
  var topCTR=EMP.filter(function(p){return p.ctr>5;}).sort(function(a,b){return b.clicks-a.clicks;})[0];
  if(topCTR)good.push({l:sp(topCTR.url).slice(0,28),v:topCTR.ctr.toFixed(1)+'% CTR'});
  good.push({l:'Avg position',v:ap.toFixed(1)+(ap<10?' ✓':' needs work')});
  var zero=EMP.filter(function(p){return p.impr>500&&p.ctr<0.5&&p.pos<15;}).sort(function(a,b){return b.impr-a.impr;});
  zero.slice(0,3).forEach(function(p){warn.push({l:sp(p.url).slice(0,28),v:fmt(p.impr)+' impr '+p.ctr.toFixed(1)+'%'});});
  var qw=EMP.filter(function(p){return p.pos>=5&&p.pos<=20;});
  var hp=EMP.filter(function(p){return p.impr>500&&p.ctr<2&&p.pos<30;});
  opp.push({l:qw.length+' quick wins (pos 5-20)',v:'Push to p1'});
  opp.push({l:hp.length+' high potential',v:'Fix CTR'});
  if(BLOGS.length){var bh=BLOGS.filter(function(p){return p.impr>300&&p.ctr<2;});if(bh.length)opp.push({l:bh.length+' B2B blog opps',v:'Low CTR'});}

  function sigR(arr){return arr.map(function(s){return'<div class="sig-row"><span class="sig-l">'+esc(s.l)+'</span><span class="sig-v">'+esc(s.v)+'</span></div>';}).join('');}

  var h=dbg;
  h+='<div style="font-size:10px;font-weight:700;color:var(--mut);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;">Employers Section</div>';
  h+='<div class="stat-grid">';
  h+='<div class="stat blue"><div class="stat-lbl">Total Clicks</div><div class="stat-val">'+fmt(tc)+'</div><div class="stat-sub">'+EMP.length+' pages</div></div>';
  h+='<div class="stat green"><div class="stat-lbl">Impressions</div><div class="stat-val">'+fmt(ti)+'</div><div class="stat-sub">Search appearances</div></div>';
  h+='<div class="stat amber"><div class="stat-lbl">Avg CTR</div><div class="stat-val">'+ac.toFixed(1)+'%</div><div class="stat-sub">'+(ac<2?'⚠ Below 2%':'On track')+'</div></div>';
  h+='<div class="stat purple"><div class="stat-lbl">Avg Position</div><div class="stat-val">'+ap.toFixed(1)+'</div><div class="stat-sub">'+(ap<10?'Good':'Needs work')+'</div></div>';
  h+='</div>';
  if(BLOGS.length){
    h+='<div style="font-size:10px;font-weight:700;color:var(--mut);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;">B2B Blog Section</div>';
    h+='<div class="stat-grid">';
    var bap=BLOGS.reduce(function(s,p){return s+p.pos;},0)/BLOGS.length;
    h+='<div class="stat blue"><div class="stat-lbl">Blog Clicks</div><div class="stat-val">'+fmt(btc)+'</div><div class="stat-sub">'+BLOGS.length+' blogs</div></div>';
    h+='<div class="stat green"><div class="stat-lbl">Blog Impressions</div><div class="stat-val">'+fmt(bti)+'</div><div class="stat-sub">Appearances</div></div>';
    h+='<div class="stat amber"><div class="stat-lbl">Blog Avg CTR</div><div class="stat-val">'+bac.toFixed(1)+'%</div><div class="stat-sub">'+(bac<2?'⚠ Fix titles':'Good')+'</div></div>';
    h+='<div class="stat purple"><div class="stat-lbl">Blog Avg Pos</div><div class="stat-val">'+bap.toFixed(1)+'</div><div class="stat-sub">'+(bap<10?'Strong':'Needs links')+'</div></div>';
    h+='</div>';
  } else {
    h+='<div class="notice nb" style="margin-bottom:14px;"><div class="n-t">ℹ️ B2B Blog tracking not set up</div><div class="n-b">Go to "Setup Blog URLs" tab → paste your 83 B2B blog URLs → click Save.</div></div>';
  }
  h+='<div class="sigs">';
  h+='<div class="sig sig-g"><div class="sig-t">✅ Working</div>'+sigR(good.length?good:[{l:'Upload data',v:''}])+'</div>';
  h+='<div class="sig sig-r"><div class="sig-t">⚠ Attention</div>'+sigR(warn.length?warn:[{l:'No critical issues',v:'✓'}])+'</div>';
  h+='<div class="sig sig-a"><div class="sig-t">🚀 Opportunities</div>'+sigR(opp)+'</div>';
  h+='</div>';
  h+='<div class="two">';
  h+='<div class="card" style="margin-bottom:0"><div class="card-h">Top /employers/ pages<span class="card-sub">click URL to open · click 🔍 for queries</span></div><div class="tw"><table><thead><tr><th>#</th><th>URL</th><th>Clicks</th><th>CTR</th><th>Pos.</th><th></th></tr></thead><tbody>';
  EMP.slice(0,10).forEach(function(p,i){
    h+='<tr><td style="color:var(--mut);font-size:10px;">'+(i+1)+'</td>'+urlTd(p.url)+'<td style="font-weight:600;color:var(--blue);">'+fmt(p.clicks)+'</td><td>'+ctrT(p.ctr)+'</td><td>'+posT(p.pos)+'</td><td><button onclick="showPageQueries(\''+esc(p.url.replace(/'/g,"\\'"))+'\')" style="padding:2px 6px;background:var(--surf3);color:var(--mut);border:none;border-radius:4px;cursor:pointer;font-size:10px;">🔍</button></td></tr>';
  });
  h+='</tbody></table></div></div>';
  h+='<div class="card" style="margin-bottom:0"><div class="card-h">Top B2B Blogs<span class="card-sub">'+(BLOGS.length?BLOGS.length+' tracked':'not set up')+'</span></div>';
