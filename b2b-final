<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Unstop B2B SEO Dashboard</title>
<!-- SheetJS for local Excel parsing -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#0c0e14;--surf:#13151f;--surf2:#1a1d2b;--surf3:#222538;
  --bdr:#2a2d3e;--bdr2:#353850;
  --txt:#e8eaf0;--mut:#7a7f9a;--fnt:#3a3d52;
  --blue:#4f8ef7;--bdim:#1e3a6e;
  --green:#34d399;--gdim:#064e3b;
  --amber:#fbbf24;--adim:#78350f;
  --red:#f87171;--rdim:#7f1d1d;
  --purple:#a78bfa;--pdim:#3b1d8a;
  --orange:#fb923c;--odim:#7c2d12;
  --teal:#2dd4bf;--tdim:#134e4a;
}
body{font-family:system-ui,-apple-system,sans-serif;background:var(--bg);color:var(--txt);font-size:13px;min-height:100vh;}

/* UPLOAD */
#upload-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:2rem;background:radial-gradient(ellipse at 20% 50%,#1a1d40 0%,var(--bg) 60%);}
.up-wrap{max-width:500px;width:100%;}
.up-brand{font-size:11px;font-weight:700;color:var(--mut);letter-spacing:.14em;text-transform:uppercase;margin-bottom:2rem;display:flex;align-items:center;gap:8px;}
.up-brand::before{content:'';width:8px;height:8px;border-radius:50%;background:var(--blue);display:block;}
.up-h1{font-size:28px;font-weight:700;line-height:1.2;margin-bottom:.6rem;}
.up-h1 span{color:var(--blue);}
.up-sub{font-size:12px;color:var(--mut);line-height:1.7;margin-bottom:1.75rem;}
.drop{border:1.5px dashed var(--bdr2);border-radius:14px;padding:2.5rem;text-align:center;cursor:pointer;transition:.2s;position:relative;background:var(--surf);}
.drop:hover,.drop.over{border-color:var(--blue);background:var(--surf2);}
.drop input{position:absolute;inset:0;opacity:0;cursor:pointer;}
.drop-ico{width:48px;height:48px;background:var(--bdim);border-radius:10px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;}
.drop-t{font-size:14px;font-weight:600;margin-bottom:4px;}
.drop-s{font-size:11px;color:var(--mut);}
.how{margin-top:1.5rem;background:var(--surf2);border-radius:10px;padding:1rem;}
.how-t{font-size:9px;font-weight:700;color:var(--mut);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;}
.how-row{display:flex;align-items:flex-start;gap:8px;margin-bottom:5px;font-size:11px;color:var(--mut);}
.how-n{min-width:17px;height:17px;background:var(--bdim);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:var(--blue);}
.err{background:#2d1515;border:1px solid var(--rdim);border-radius:8px;padding:10px;font-size:11px;color:var(--red);margin-top:10px;display:none;}

/* LAYOUT */
#dashboard{display:none;}
.sb{width:214px;background:var(--surf);border-right:1px solid var(--bdr);height:100vh;position:fixed;left:0;top:0;display:flex;flex-direction:column;z-index:50;overflow:hidden;}
.sb-logo{padding:14px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;gap:8px;flex-shrink:0;}
.sb-dot{width:8px;height:8px;border-radius:50%;background:var(--blue);}
.sb-name{font-size:12px;font-weight:700;}
.sb-badge{font-size:9px;background:var(--bdim);color:var(--blue);padding:2px 6px;border-radius:4px;font-weight:600;margin-left:auto;}
.sb-nav{padding:6px;flex:1;overflow-y:auto;scrollbar-width:none;}
.sb-nav::-webkit-scrollbar{display:none;}
.sb-sec{font-size:9px;font-weight:700;color:var(--fnt);text-transform:uppercase;letter-spacing:.12em;padding:4px 8px;margin:8px 0 2px;}
.sb-item{display:flex;align-items:center;gap:6px;padding:6px 8px;border-radius:7px;cursor:pointer;font-size:11px;color:var(--mut);font-weight:500;transition:.15s;margin-bottom:1px;}
.sb-item:hover{background:var(--surf2);color:var(--txt);}
.sb-item.active{background:var(--bdim);color:var(--blue);}
.sb-item svg{width:13px;height:13px;flex-shrink:0;}
.sb-cnt{margin-left:auto;font-size:10px;background:var(--surf3);color:var(--mut);padding:1px 5px;border-radius:99px;}
.sb-item.active .sb-cnt{background:rgba(79,142,247,.2);color:var(--blue);}
.sb-bot{padding:8px;border-top:1px solid var(--bdr);flex-shrink:0;}
.sb-up{width:100%;padding:7px;background:var(--surf2);color:var(--mut);border:1px solid var(--bdr2);border-radius:7px;font-size:11px;font-weight:600;cursor:pointer;transition:.15s;}
.sb-up:hover{color:var(--txt);}

.content{margin-left:214px;min-height:100vh;display:flex;flex-direction:column;}
.topbar{background:var(--surf);border-bottom:1px solid var(--bdr);padding:0 20px;height:52px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:40;flex-shrink:0;}
.tb-title{font-size:14px;font-weight:700;}
.tb-pills{display:flex;gap:7px;}
.pill{font-size:10px;padding:3px 9px;border-radius:99px;border:1px solid;font-weight:600;}
.pill-blue{color:var(--blue);border-color:var(--bdim);background:var(--bdim);}
.pill-green{color:var(--green);border-color:var(--gdim);background:var(--gdim);}
.pill-amber{color:var(--amber);border-color:var(--adim);background:var(--adim);}

.main{padding:20px;flex:1;}
.tab-sec{display:none;}
.tab-sec.active{display:block;}

/* CARDS */
.card{background:var(--surf);border:1px solid var(--bdr);border-radius:12px;padding:16px 18px;margin-bottom:14px;}
.card-h{font-size:12px;font-weight:700;color:var(--txt);margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;gap:8px;}
.card-sub{font-size:10px;color:var(--mut);font-weight:400;}
.two{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;}
.three{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:12px;}

/* STAT CARDS */
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;}
.stat{background:var(--surf);border:1px solid var(--bdr);border-radius:12px;padding:14px 16px;position:relative;overflow:hidden;}
.stat::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.stat.blue::before{background:var(--blue);}
.stat.green::before{background:var(--green);}
.stat.amber::before{background:var(--amber);}
.stat.purple::before{background:var(--purple);}
.stat.red::before{background:var(--red);}
.stat.teal::before{background:var(--teal);}
.stat-lbl{font-size:9px;font-weight:700;color:var(--mut);text-transform:uppercase;letter-spacing:.08em;margin-bottom:7px;}
.stat-val{font-size:26px;font-weight:700;line-height:1;margin-bottom:3px;}
.stat.blue .stat-val{color:var(--blue);}
.stat.green .stat-val{color:var(--green);}
.stat.amber .stat-val{color:var(--amber);}
.stat.purple .stat-val{color:var(--purple);}
.stat.red .stat-val{color:var(--red);}
.stat.teal .stat-val{color:var(--teal);}
.stat-sub{font-size:10px;color:var(--mut);}

/* TABLE */
.tw{overflow-x:auto;}
table{width:100%;border-collapse:collapse;}
th{text-align:left;font-size:9px;font-weight:700;color:var(--mut);padding:6px 10px;border-bottom:1px solid var(--bdr);white-space:nowrap;letter-spacing:.06em;text-transform:uppercase;background:var(--surf2);}
td{padding:7px 10px;border-bottom:1px solid var(--bdr);font-size:11px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:var(--surf2);}
a.url-link{color:var(--blue);text-decoration:none;font-size:10px;font-family:monospace;}
a.url-link:hover{text-decoration:underline;}

/* BADGES */
.b{display:inline-block;font-size:10px;font-weight:600;padding:2px 6px;border-radius:4px;}
.bg{background:var(--gdim);color:var(--green);}
.bb{background:var(--bdim);color:var(--blue);}
.ba{background:var(--adim);color:var(--amber);}
.br{background:var(--rdim);color:var(--red);}
.bp{background:var(--pdim);color:var(--purple);}
.bt{background:var(--tdim);color:var(--teal);}
.bx{background:var(--surf3);color:var(--mut);}

/* SIGNALS */
.sigs{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:16px;}
.sig{border-radius:10px;padding:12px;border:1px solid;}
.sig-g{background:#051f15;border-color:var(--gdim);}
.sig-r{background:#1f0505;border-color:var(--rdim);}
.sig-a{background:#1f1405;border-color:var(--adim);}
.sig-t{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:8px;}
.sig-g .sig-t{color:var(--green);}
.sig-r .sig-t{color:var(--red);}
.sig-a .sig-t{color:var(--amber);}
.sig-row{display:flex;justify-content:space-between;align-items:center;padding:3px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:11px;}
.sig-row:last-child{border-bottom:none;}
.sig-l{color:var(--mut);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-right:8px;}
.sig-v{font-weight:600;white-space:nowrap;font-size:10px;}
.sig-g .sig-v{color:var(--green);}
.sig-r .sig-v{color:var(--red);}
.sig-a .sig-v{color:var(--amber);}

/* URL BAR */
.url-bars .ur{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--bdr);}
.url-bars .ur:last-child{border-bottom:none;}
.up{font-family:monospace;font-size:10px;color:var(--mut);min-width:180px;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.bw{flex:1;}
.bg2{height:4px;background:var(--surf3);border-radius:2px;overflow:hidden;}
.bf{height:100%;border-radius:2px;}
.us2{display:flex;gap:10px;}
.uv{font-size:11px;font-weight:600;}
.ul{font-size:9px;color:var(--mut);text-transform:uppercase;font-weight:600;}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:200;display:none;align-items:flex-start;justify-content:center;padding:40px 20px;overflow-y:auto;}
.modal-overlay.open{display:flex;}
.modal{background:var(--surf);border:1px solid var(--bdr2);border-radius:14px;width:100%;max-width:900px;max-height:80vh;overflow-y:auto;}
.modal-head{padding:16px 20px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--surf);z-index:1;}
.modal-title{font-size:14px;font-weight:700;}
.modal-close{width:28px;height:28px;background:var(--surf2);border:none;border-radius:6px;cursor:pointer;color:var(--mut);font-size:16px;display:flex;align-items:center;justify-content:center;}
.modal-body{padding:16px 20px;}

/* NOTICE */
.notice{border-radius:10px;padding:10px 14px;margin-bottom:12px;border:1px solid;}
.nb{background:var(--bdim);border-color:rgba(79,142,247,.3);}
.na{background:var(--adim);border-color:rgba(251,191,36,.3);}
.ng{background:var(--gdim);border-color:rgba(52,211,153,.3);}
.nr{background:var(--rdim);border-color:rgba(248,113,113,.3);}
.n-t{font-size:11px;font-weight:700;margin-bottom:2px;}
.nb .n-t{color:var(--blue);}
.na .n-t{color:var(--amber);}
.ng .n-t{color:var(--green);}
.nr .n-t{color:var(--red);}
.n-b{font-size:11px;color:var(--mut);}

/* TEXTAREA / BUTTONS */
.ta{width:100%;min-height:130px;background:var(--surf);border:1px solid var(--bdr2);border-radius:8px;padding:10px;font-family:monospace;font-size:11px;color:var(--txt);resize:vertical;outline:none;line-height:1.7;}
.ta:focus{border-color:var(--blue);}
.ta::placeholder{color:var(--fnt);}
.btn-row{display:flex;gap:7px;flex-wrap:wrap;margin-top:8px;}
.btn{padding:6px 14px;border-radius:7px;font-size:11px;font-weight:600;cursor:pointer;border:none;transition:.15s;}
.btn-p{background:var(--blue);color:#fff;}
.btn-p:hover{opacity:.88;}
.btn-g{background:var(--surf3);color:var(--mut);border:1px solid var(--bdr2);}
.btn-g:hover{color:var(--txt);}

/* CLUSTER CARDS */
.cl-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px;}
.cl-card{background:var(--surf);border:1px solid var(--bdr);border-radius:11px;padding:14px;cursor:pointer;transition:.2s;border-top-width:2px;}
.cl-card:hover{border-color:var(--blue);transform:translateY(-1px);}
.cl-icon{font-size:20px;margin-bottom:8px;}
.cl-name{font-size:11px;font-weight:700;color:var(--txt);margin-bottom:4px;}
.cl-val{font-size:22px;font-weight:700;margin-bottom:2px;}
.cl-meta{font-size:10px;color:var(--mut);}
.cl-bar-bg{height:3px;background:var(--surf3);border-radius:2px;margin-top:8px;overflow:hidden;}
.cl-bar-fill{height:100%;border-radius:2px;}
.cl-hint{font-size:9px;color:var(--fnt);margin-top:4px;text-align:right;}

/* ACTION */
.act-row{display:flex;gap:10px;padding:10px 0;border-bottom:1px solid var(--bdr);}
.act-row:last-child{border-bottom:none;}
.act-n{min-width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;flex-shrink:0;margin-top:2px;}
.act-title{font-size:12px;font-weight:600;color:var(--txt);margin-bottom:3px;}
.act-sub{font-size:11px;color:var(--mut);line-height:1.6;}
.act-imp{display:inline-block;font-size:9px;font-weight:700;padding:2px 7px;border-radius:4px;margin-top:4px;}

/* AEO */
.aeo-sec{background:var(--surf);border:1.5px solid var(--bdr);border-radius:12px;margin-bottom:10px;overflow:hidden;}
.aeo-hdr{display:flex;align-items:center;gap:10px;padding:11px 16px;cursor:pointer;transition:.15s;}
.aeo-hdr:hover{background:var(--surf2);}
.aeo-ico{font-size:16px;flex-shrink:0;}
.aeo-htitle{font-size:12px;font-weight:700;flex:1;}
.aeo-cnt{font-size:18px;font-weight:700;}
.aeo-arr{font-size:10px;color:var(--mut);}
.aeo-body{display:none;padding:0 0 4px;}

/* REGEX */
.rx-card{background:var(--surf);border:1px solid var(--bdr);border-radius:10px;margin-bottom:8px;overflow:hidden;border-left-width:3px;}
.rx-head{display:flex;align-items:center;gap:8px;padding:10px 14px;cursor:pointer;}
.rx-head:hover{background:var(--surf2);}
.rx-badge{min-width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;flex-shrink:0;}
.rx-title{font-size:11px;font-weight:700;color:var(--txt);flex:1;}
.rx-desc{font-size:10px;color:var(--mut);margin-top:1px;}
.rx-stats{display:flex;gap:10px;text-align:right;flex-shrink:0;}
.rx-sv{font-size:11px;font-weight:700;}
.rx-sl{font-size:9px;color:var(--mut);text-transform:uppercase;}
.rx-body{display:none;padding:0 14px 12px;}
.rx-tip{font-size:11px;color:var(--mut);background:var(--surf2);border-radius:6px;padding:7px 10px;margin-bottom:8px;line-height:1.6;}
.rx-code{font-family:monospace;font-size:10px;background:var(--surf3);border-radius:5px;padding:5px 8px;color:var(--green);margin-bottom:8px;display:flex;align-items:center;justify-content:space-between;}

@media(max-width:1024px){.sb{display:none;}.content{margin-left:0;}.stat-grid{grid-template-columns:1fr 1fr;}.two,.three,.cl-grid{grid-template-columns:1fr;}.sigs{grid-template-columns:1fr;}}
</style>
</head>
<body>

<div id="upload-screen">
  <div class="up-wrap">
    <div class="up-brand">Unstop · B2B SEO Intelligence</div>
    <h1 class="up-h1">B2B SEO<br><span>Dashboard</span></h1>
    <p class="up-sub">Upload GSC Performance export. Dashboard auto-segments <strong style="color:var(--txt)">/employers/</strong> pages + tracks B2B blogs separately.</p>
    <div class="drop" id="dropZone">
      <input type="file" id="fileInput" accept=".xlsx,.xls,.csv">
      <div class="drop-ico"><svg width="22" height="22" fill="none" stroke="#4f8ef7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg></div>
      <div class="drop-t">Drop GSC Excel file here</div>
      <div class="drop-s">or click to browse · .xlsx supported</div>
    </div>
    <div class="how">
      <div class="how-t">How to export</div>
      <div class="how-row"><div class="how-n">1</div><span>GSC → Performance → Date range → Export → Excel</span></div>
      <div class="how-row"><div class="how-n">2</div><span>Optional: filter by Page: +/employers/ before export</span></div>
      <div class="how-row"><div class="how-n">3</div><span>Upload here → /employers/ auto-detected</span></div>
    </div>
    <div class="err" id="errMsg"></div>
  </div>
</div>

<div id="dashboard">
  <div class="sb">
    <div class="sb-logo"><div class="sb-dot"></div><div class="sb-name">B2B SEO Dash</div><div class="sb-badge">UNSTOP</div></div>
    <div class="sb-nav">
      <div class="sb-sec">Overview</div>
      <div class="sb-item active" data-tab="overview" onclick="ST('overview',this)">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>B2B Overview<span class="sb-cnt" id="cnt-ov">—</span>
      </div>
      <div class="sb-sec">Employers Pages</div>
      <div class="sb-item" data-tab="employers" onclick="ST('employers',this)">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>All Pages<span class="sb-cnt" id="cnt-emp">—</span>
      </div>
      <div class="sb-item" data-tab="clusters" onclick="ST('clusters',this)">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>Product Clusters
      </div>
      <div class="sb-item" data-tab="emp-wins" onclick="ST('emp-wins',this)">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>Quick Wins<span class="sb-cnt" id="cnt-qw">—</span>
      </div>
      <div class="sb-item" data-tab="emp-hp" onclick="ST('emp-hp',this)">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>High Potential<span class="sb-cnt" id="cnt-hp">—</span>
      </div>
      <div class="sb-sec">B2B Blog Tracker</div>
      <div class="sb-item" data-tab="blog-setup" onclick="ST('blog-setup',this)">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4"/></svg>Setup Blog URLs
      </div>
      <div class="sb-item" data-tab="blogs" onclick="ST('blogs',this)">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>Blog Performance<span class="sb-cnt" id="cnt-bl">—</span>
      </div>
      <div class="sb-sec">Intelligence</div>
      <div class="sb-item" data-tab="regex" onclick="ST('regex',this)">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>B2B Regex Library
      </div>
      <div class="sb-item" data-tab="aeo" onclick="ST('aeo',this)">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>AEO / GEO Signals
      </div>
      <div class="sb-item" data-tab="actions" onclick="ST('actions',this)">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>Action Items
      </div>
      <div class="sb-item" data-tab="roadmap" onclick="ST('roadmap',this)">
